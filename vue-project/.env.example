# Vite does NOT load this filename. Copy this file to `.env` in this folder
# (same directory as package.json) and put your real token there.
#
#   cp .env.example .env
#
# Then restart `npm run dev` / `npm run build`.
#
# GitHub Pages: add repository secret VITE_MAPBOX_TOKEN (same name as this var);
# the publish workflow passes it into `npm run build`.

VITE_MAPBOX_TOKEN=your_mapbox_token_here
# Optional alternative (also supported):
# MAPBOX_TOKEN=your_mapbox_token_here
